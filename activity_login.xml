<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_soft">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="0dp"
        android:background="@drawable/glass_panel_bg"
        android:elevation="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="50dp"
        android:paddingBottom="50dp">

        <!-- Logo Image -->
        <ImageView
            android:id="@+id/logoImg"
            android:layout_width="480dp"
            android:layout_height="240dp"
            android:layout_marginBottom="0dp"
            android:adjustViewBounds="true"
            android:src="@drawable/trans_logo"
            android:scaleType="fitCenter" />

        <!-- Account Name Input Group -->
        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="250dp"
                android:layout_height="40dp"
                android:background="@drawable/brand_gradient"
                android:padding="0.1dp">

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center"
                    android:hint=""
                    android:inputType="text"
                    android:textColor="@color/indigo"
                    android:fontFamily="@font/helveticathin"
                    android:textSize="16sp"
                    android:importantForAutofill="no" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvAccountNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Account Number"
                android:textStyle="bold"
                android:fontFamily="@font/helvetica"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Password Input Group -->
        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="35dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="250dp"
                android:layout_height="40dp"
                android:background="@drawable/brand_gradient"
                android:padding="0.1dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center"
                    android:hint=""
                    android:inputType="textPassword"
                    android:textColor="@color/indigo"
                    android:fontFamily="@font/helveticathin"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Password"
                android:textStyle="bold"
                android:fontFamily="@font/helvetica"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Login Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogin"
            android:layout_width="220dp"
            android:layout_height="35dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/brand_gradient"
            android:text="LOGIN"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:fontFamily="@font/qurova"
            android:textSize="14sp"
            android:elevation="4dp" />

        <!-- Sign Up Button -->
        <FrameLayout
            android:layout_width="220dp"
            android:layout_height="35dp"
            android:layout_marginBottom="50dp"
            android:background="@drawable/brand_gradient"
            android:padding="0.5dp">
            
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSignup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/input_field_bg"
                android:text="SIGN UP"
                android:textStyle="bold"
                android:fontFamily="@font/qurova"
                android:textSize="14sp" />
        </FrameLayout>

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ride with Ease, Pedal with Peace."
            android:textStyle="bold"
            android:fontFamily="@font/qurova"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</FrameLayout>