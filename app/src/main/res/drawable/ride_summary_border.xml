<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The Gradient Border -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/brand_purple"
                android:startColor="@color/brand_gold" />
            <corners android:radius="50dp" />
        </shape>
    </item>
    <!-- The Inner White Background -->
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="42dp" />
        </shape>
    </item>
</layer-list>