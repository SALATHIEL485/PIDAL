<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <!-- Main Dialog Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="32dp"
        app:cardElevation="10dp"
        app:strokeColor="@color/brand_purple"
        app:strokeWidth="1.5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Checkered Top Border -->
            <ImageView
                android:id="@+id/ivTopCheckered"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                android:src="@drawable/behind"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Middle Section: Flag & Animated Button Row -->
            <LinearLayout
                android:id="@+id/llConfirmRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/ivTopCheckered">

                <!-- Purple Flag Icon -->
                <ImageView
                    android:id="@+id/ivFlag"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/flag" />

                <View android:layout_width="12dp" android:layout_height="0dp" />

                <!-- The Lottie Animation IS the Button -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottieConfirmAnim"
                    android:layout_width="140dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="false"
                    app:lottie_rawRes="@raw/confirm_stop"
                    android:clickable="false"
                    android:focusable="false" />

            </LinearLayout>

            <!-- Nearest Station Info -->
            <LinearLayout
                android:id="@+id/llStationInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llConfirmRow">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/helveticathin"
                    android:text="NEAREST STATION:"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/bike_loc"
                        app:tint="@color/brand_purple" />
                    <TextView
                        android:id="@+id/tvNearestStationDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/poppins"
                        android:text="Locating..."
                        android:textColor="@color/brand_purple"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Checkered Bottom Border -->
            <ImageView
                android:id="@+id/ivBottomCheckered"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                android:src="@drawable/behind"
                app:layout_constraintTop_toBottomOf="@id/llStationInfo" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
