<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_soft">

    <!-- Background Pattern Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_img"
        android:alpha="0.1" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="40dp"
            android:paddingBottom="40dp">

            <!-- Title (Scaled up 30%) -->
            <TextView
                android:id="@+id/tvSignUpTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/qurova"
                android:text="SIGN UP"
                android:textColor="@color/brand_purple"
                android:textSize="42sp"
                android:textStyle="bold" />

            <!-- Yellow Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="20dp"
                android:background="@color/brand_gold" />

            <!-- Form Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical">

                <!-- First Name Row (Height increased 30%) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/pill_label_bg">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="FIRST NAME:"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/qurova" />

                    <EditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="106dp"
                        android:layout_marginVertical="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/pill_input_bg"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:fontFamily="@font/helveticathin"
                        android:inputType="textPersonName"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Middle Name Row -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/pill_label_bg">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="MIDDLE NAME:"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/qurova" />

                    <EditText
                        android:id="@+id/etMiddleInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="106dp"
                        android:layout_marginVertical="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/pill_input_bg"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:fontFamily="@font/helveticathin"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Last Name Row -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/pill_label_bg">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="LAST NAME:"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/qurova" />

                    <EditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="106dp"
                        android:layout_marginVertical="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/pill_input_bg"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:fontFamily="@font/helveticathin"
                        android:inputType="textPersonName"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Middle Yellow Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginVertical="20dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/brand_gold" />

                <!-- Mobile Number Row -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/pill_label_bg">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="MOBILE\nNUMBER:"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/qurova" />

                    <EditText
                        android:id="@+id/etMobileNumber"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="106dp"
                        android:layout_marginVertical="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/pill_input_bg"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="@font/helveticathin"
                        android:inputType="phone"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Password Row -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="35dp"
                    android:background="@drawable/pill_label_bg">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="PASSWORD:"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/qurova" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="106dp"
                        android:layout_marginVertical="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/pill_input_bg"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:fontFamily="@font/helveticathin"
                        android:inputType="textPassword"
                        android:gravity="center_vertical" />
                </FrameLayout>
            </LinearLayout>

            <!-- Register Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/brand_gradient"
                android:text="REGISTER"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/qurova" />

            <!-- Back Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBackToLogin"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/pill_input_bg"
                android:text="GO BACK TO LOGIN"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/qurova" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
